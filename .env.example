# ── LLM API keys (at least one required for AI-generated commit messages and PR bodies) ──
#
# Claude (recommended): https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI (fallback if Anthropic key is absent): https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...


# ── Git platform tokens ────────────────────────────────────────────────────────
#
# GitHub — only needed if the gh CLI is not installed/authenticated
# GITHUB_TOKEN=ghp_...
#
# Bitbucket Server — HTTP access token from Personal Settings → HTTP access tokens
# BITBUCKET_TOKEN=...
#
# Bitbucket Server base URL (required for self-hosted installs)
# BITBUCKET_SERVER_URL=https://bitbucket.mycompany.com


# ── Ticket / issue tracking ────────────────────────────────────────────────────
#
# Regex to extract the ticket ID from the branch name.
# Default matches Jira / Linear / YouTrack style (e.g. AUTH-42, PLAT-7).
# TICKET_PATTERN=[A-Z]+-[0-9]+
#
# Other examples:
#   TICKET_PATTERN=[0-9]+          # GitHub / GitLab issue numbers
#   TICKET_PATTERN=sc-[0-9]+       # Shortcut
#   TICKET_PATTERN=AB#[0-9]+       # Azure DevOps
#
# URL template for linking to a ticket in PR bodies. Use {id} as the placeholder.
# TICKET_URL_TEMPLATE=https://yourorg.atlassian.net/browse/{id}   # Jira
# TICKET_URL_TEMPLATE=https://linear.app/myteam/issue/{id}        # Linear
# TICKET_URL_TEMPLATE=https://github.com/org/repo/issues/{id}     # GitHub issues


# ── Editor (used when no LLM key is set) ──────────────────────────────────────
#
# EDITOR=vim
# VISUAL=code --wait
